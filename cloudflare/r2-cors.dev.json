{
  "rules": [
    {
      "allowed": {
        "origins": [
          "http://localhost:5173",
          "http://127.0.0.1:5173"
        ],
        "methods": [
          "GET",
          "PUT",
          "HEAD"
        ],
        "headers": [
          "Content-Type",
          "Range"
        ]
      },
      "exposeHeaders": [
        "Accept-Ranges",
        "Content-Length",
        "Content-Range",
        "Content-Type",
        "ETag"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
