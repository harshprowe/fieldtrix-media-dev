APP_NAME=FieldTrix Media Delivery System
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173

DATABASE_URL=URL
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

JWT_SECRET_KEY=replace_with_secure_random_value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

LOG_LEVEL=info

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
R2_REGION_NAME=auto
R2_PRESIGNED_UPLOAD_EXPIRE_SECONDS=900
R2_PRESIGNED_DOWNLOAD_EXPIRE_SECONDS=900
R2_MAX_UPLOAD_SIZE_BYTES=536870912
